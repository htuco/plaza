# Supabase — DB, Realtime, anon auth (see context/project-spec.md §2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for Drizzle migrations (Supabase pooler URL recommended)
DATABASE_URL=

# Spotify — host-only OAuth for Guess the Song (project-spec.md §4)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# iTunes Search API needs no key.

# Optional AI validation for Gradovi i Sela
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GRADOVI_AI_CONFIDENCE_THRESHOLD=0.65
GRADOVI_AI_MAX_CANDIDATES=20
GRADOVI_AI_EXTRA_CONTEXT=
